root = true

[*.cs]

########################################
# Indentation & formatting
########################################

indent_style = space
indent_size = 4
insert_final_newline = true

########################################
# Braces (ALWAYS new line)
########################################

csharp_new_line_before_open_brace = all

########################################
# VAR usage
########################################

csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

########################################
# Expression-bodied members
########################################

csharp_style_expression_bodied_methods = false:suggestion

########################################
# 'this.' usage
########################################

dotnet_style_qualification_for_field = false:suggestion

########################################
# NAMING CONVENTIONS
########################################

# --------------------
# PRIVATE FIELDS → _camelCase
# --------------------
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_style.required_prefix = _
dotnet_naming_style.underscore_style.capitalization = camel_case


# --------------------
# PUBLIC MEMBERS → PascalCase
# --------------------
dotnet_naming_rule.public_members_pascal.severity = warning
dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal_style

dotnet_naming_symbols.public_members.applicable_kinds = field, property, method
dotnet_naming_symbols.public_members.applicable_accessibilities = public

dotnet_naming_style.pascal_style.capitalization = pascal_case


# --------------------
# PROPERTIES → PascalCase
# --------------------
dotnet_naming_rule.properties_pascal.severity = warning
dotnet_naming_rule.properties_pascal.symbols = properties
dotnet_naming_rule.properties_pascal.style = pascal_style

dotnet_naming_symbols.properties.applicable_kinds = property


# --------------------
# CLASSES → PascalCase
# --------------------
dotnet_naming_rule.classes_pascal.severity = warning
dotnet_naming_rule.classes_pascal.symbols = classes
dotnet_naming_rule.classes_pascal.style = pascal_style

dotnet_naming_symbols.classes.applicable_kinds = class


# --------------------
# ENUMS → PascalCase
# --------------------
dotnet_naming_rule.enums_pascal.severity = warning
dotnet_naming_rule.enums_pascal.symbols = enums
dotnet_naming_rule.enums_pascal.style = pascal_style

dotnet_naming_symbols.enums.applicable_kinds = enum


# --------------------
# CONSTANTS → UPPER_CASE
# --------------------
dotnet_naming_rule.constants_upper.severity = suggestion
dotnet_naming_rule.constants_upper.symbols = constants
dotnet_naming_rule.constants_upper.style = upper_style

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_style.upper_style.capitalization = all_upper


########################################
# CODE QUALITY / WARNINGS
########################################

# Unused variables
dotnet_diagnostic.CS0168.severity = warning

# Unused fields
dotnet_diagnostic.CS0649.severity = warning

# Prefer readonly
dotnet_diagnostic.IDE0044.severity = suggestion

# Simplify expressions
dotnet_diagnostic.IDE0003.severity = suggestion

########################################
# USINGS
########################################

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true